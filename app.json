{
  "expo": {
    "name": "EasyDine",
    "slug": "easydine",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.easydine.app"
    },
    "android": {
      "package": "com.easydine.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      ["expo-build-properties", { "android": { "kotlinVersion": "1.9.25" } }],
      ["onesignal-expo-plugin", { "mode": "production" }],
      ["expo-camera", { "cameraPermission": "EasyDine uses the camera to scan QR pairing codes." }]
    ],
    "scheme": "easydine",
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "fa97062e-ee0b-4bdc-a739-8d6a1586518d" }
    },
    "owner": "1208mpho"
  }
}
