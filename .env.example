# ─── EasyDine Environment Variables ──────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit the filled-in .env file to source control.
#
# Prefix EXPO_PUBLIC_ means the variable is bundled into the app binary.
# Variables without this prefix are server-side only.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in your Supabase project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://piyfojswoxzhhflweldf.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBpeWZvanN3b3h6aGhmbHdlbGRmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTEwNjAzNzQsImV4cCI6MjA2NjYzNjM3NH0.2zfK2HnalVOScpbPIc-_wrILchq1rzoIeQZ5pTwE9lo

# ── OneSignal ─────────────────────────────────────────────────────────────────
# Found in OneSignal Dashboard → App → Settings → Keys & IDs
EXPO_PUBLIC_ONESIGNAL_APP_ID=18516768-760d-4335-966f-efabc39d1610

# REST API key is server-side only — set it in Supabase → Edge Functions → Secrets
# ONESIGNAL_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx   ← Supabase secret, NOT here

# ── Branch / Restaurant ───────────────────────────────────────────────────────
# The branch this app build is deployed for (patron tablets with no login).
# MUST be a real UUID from public.branches in Supabase — NOT a placeholder string.
# Bad value → Postgres error 22P02 and menu/theme queries fail.
# After changing, restart Metro with --clear (EXPO_PUBLIC_* is baked in at bundle time).
EXPO_PUBLIC_BRANCH_ID=f6cbfe3b-dd2f-481b-90aa-df9c42208a3a

# ── EAS / Expo (optional local overrides) ────────────────────────────────────
# These are typically set in eas.json, not here.
# EXPO_PUBLIC_APP_ENV=production
